# SpeedRay — copy to .env and set values (no secrets in repo)

# Frontend (Vite) — Auth0: use SPA app type; do not put client secret in frontend
VITE_API_BASE=http://localhost:8001
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
# VITE_AUTH0_AUDIENCE=   # optional: Auth0 API identifier if you need access tokens
# Must match Auth0 Dashboard: Allowed Callback / Logout / Web Origins (use port Vite prints)
# VITE_AUTH0_CALLBACK_URL=http://localhost:3006/callback
# VITE_AUTH0_LOGOUT_URL=http://localhost:3006
# VITE_AUTH0_WEB_ORIGIN=http://localhost:3006
VITE_CLOUDINARY_CLOUD_NAME=

# Backend (see backend/config/settings.py for SPEEDRAY_* vars)
# Cloudinary (required for upload, annotations, transformed image URLs)
# SPEEDRAY_CLOUDINARY_CLOUD_NAME=your_cloud_name
# SPEEDRAY_CLOUDINARY_API_KEY=your_api_key
# SPEEDRAY_CLOUDINARY_API_SECRET=your_api_secret
# SPEEDRAY_GEMINI_API_KEY=
# SPEEDRAY_OPENAI_API_KEY=   # optional: GPT-3.5 fallback when Gemini quota/404
# SPEEDRAY_ELEVENLABS_API_KEY=
# SPEEDRAY_PRESAGE_BASE_URL=
# SPEEDRAY_BACKBOARD_BASE_URL=https://app.backboard.io/api
# SPEEDRAY_BACKBOARD_API_KEY=
# SPEEDRAY_SOLANA_RPC_URL=
# SPEEDRAY_AUTH0_DOMAIN=   # same as VITE_AUTH0_DOMAIN for JWT validation
# SPEEDRAY_AUTH0_AUDIENCE= # optional: same as VITE_AUTH0_AUDIENCE if using API
# Vultr (optional: for deploy scripts / creating VPS via Vultr API; idle shutdown on server)
# VULTR_API_KEY=
# VULTR_INSTANCE_ID=   # instance ID for idle_shutdown (halt when frontend idle)
# SPEEDRAY_IDLE_THRESHOLD_MINUTES=30
# SPEEDRAY_ACTIVITY_FILE=   # default: ./.speedray_last_activity (project root)
